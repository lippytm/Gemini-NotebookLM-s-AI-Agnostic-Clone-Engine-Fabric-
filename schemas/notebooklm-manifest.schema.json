{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lippytm.ai/schemas/notebooklm-manifest.schema.json",
  "title": "NotebookLM Fleet Manifest",
  "type": "object",
  "required": ["id", "name", "domain", "repository", "status", "source_policy", "hermes_route"],
  "properties": {
    "id": {"type": "string", "pattern": "^NLM-[0-9]{3}$"},
    "name": {"type": "string", "minLength": 3},
    "domain": {"type": "string"},
    "repository": {"type": "string", "pattern": "^[^/]+/[^/]+$"},
    "status": {"enum": ["planned", "building", "active", "review", "archived"]},
    "update_cadence": {"enum": ["daily", "weekly", "monthly", "event-driven"]},
    "source_policy": {"enum": ["approved-and-cited", "private-by-default", "public-only", "mixed-reviewed"]},
    "hermes_route": {"type": "string"},
    "fable5_enabled": {"type": "boolean", "default": false},
    "prompt11_profile": {"type": "string"},
    "owners": {"type": "array", "items": {"type": "string"}},
    "tags": {"type": "array", "items": {"type": "string"}},
    "last_reviewed": {"type": ["string", "null"], "format": "date"},
    "risk_level": {"enum": ["low", "medium", "high", "restricted"]}
  },
  "additionalProperties": false
}
